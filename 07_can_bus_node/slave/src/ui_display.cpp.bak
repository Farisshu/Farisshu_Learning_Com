#include "ui_display.h"

TFT_eSPI tft = TFT_eSPI();

void ui_init() {
    tft.init();
    delay(100);
    tft.setRotation(1);
    tft.fillScreen(TFT_BLACK);
    ui_drawStaticLayout();
}

void ui_drawStaticLayout() {
    tft.setTextColor(TFT_CYAN, TFT_BLACK);
    tft.setTextSize(1);
    tft.setCursor(8, 10);
    tft.print("CAN BUS MONITOR");
    
    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setCursor(8, 35);
    tft.print("ENGINE RPM");
    tft.setCursor(8, 85);
    tft.print("COOLANT TEMP");
}

void ui_render(const CanData_t* data, bool linkOk) {
    tft.fillRect(8, 50, 100, 25, TFT_BLACK);
    tft.fillRect(8, 100, 100, 25, TFT_BLACK);
    tft.fillRect(100, 10, 60, 15, TFT_BLACK);
    
    tft.setTextColor(TFT_YELLOW, TFT_BLACK);
    tft.setTextSize(2);
    tft.setCursor(8, 50);
    tft.print(data->rpm, 0);
    tft.setTextSize(1);
    tft.print(" RPM");
    
    tft.setTextColor(TFT_GREEN, TFT_BLACK);
    tft.setTextSize(2);
    tft.setCursor(8, 100);
    tft.print(data->temp, 1);
    tft.setTextSize(1);
    tft.print(" C");
    
    tft.setTextSize(1);
    if (!linkOk) {
        tft.setTextColor(TFT_RED, TFT_BLACK);
        tft.setCursor(105, 10);
        tft.print("NO LINK");
    } else if (data->status == 0x02) {
        tft.setTextColor(TFT_RED, TFT_BLACK);
        tft.setCursor(105, 10);
        tft.print("CRIT");
    } else if (data->status == 0x01) {
        tft.setTextColor(TFT_YELLOW, TFT_BLACK);
        tft.setCursor(105, 10);
        tft.print("WARN");
    } else {
        tft.setTextColor(TFT_GREEN, TFT_BLACK);
        tft.setCursor(105, 10);
        tft.print("OK");
    }
}