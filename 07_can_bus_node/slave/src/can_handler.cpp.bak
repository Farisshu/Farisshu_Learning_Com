#include "can_handler.h"
#include <SPI.h>
#include <mcp_can.h>

static MCP_CAN* canDev = nullptr;
static unsigned long lastRxTime = 0;

void can_init(uint8_t csPin) {
    canDev = new MCP_CAN(csPin);
    while (canDev->begin(MCP_STDEXT, CAN_250KBPS, MCP_8MHZ) != CAN_OK) {
        Serial.println("[SLAVE] CAN Init Retry...");
        delay(100);
    }
    Serial.println("[SLAVE] ✅ CAN Initialized");
}

bool can_poll(CanData_t* out) {
    if (!canDev) return false;
    
    // 🔑 WAJIB: Cek buffer sebelum baca
    if (canDev->checkReceive() == CAN_MSGAVAIL) {
        unsigned long id;
        unsigned char len;
        unsigned char buf[8];
        
        if (canDev->readMsgBuf(&id, &len, buf) == CAN_OK) {
            Serial.printf("[RX] ID:0x%03X LEN:%d\n", id, len);
            
            if (id == 0x100 && len >= 5) {
                uint16_t rpmRaw = (buf[0] << 8) | buf[1];
                uint16_t tempRaw = (buf[2] << 8) | buf[3];
                
                out->rpm = rpmRaw / 10.0;
                out->temp = tempRaw / 10.0;
                out->status = buf[4];
                out->valid = true;
                lastRxTime = millis();
                return true;
            }
        }
    }
    return false;
}

bool can_isAlive(uint32_t timeoutMs) {
    return (millis() - lastRxTime < timeoutMs);
}