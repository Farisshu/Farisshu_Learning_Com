#ifndef CAN_HANDLER_H
#define CAN_HANDLER_H

#include <Arduino.h>

#define CAN_CS_PIN 22  // ← PAKAI PIN INI (sudah terbukti jalan)

typedef struct {
    float rpm;
    float temp;
    uint8_t status;
    bool valid;
} CanData_t;

void can_init(uint8_t csPin);
bool can_poll(CanData_t* out);
bool can_isAlive(uint32_t timeoutMs);

#endif